#!/usr/bin/env bash

set -euo pipefail
shopt -s nocasematch

if [ -z "${QUTE_FIFO:-}" ]; then
    echo 'This script must be run by qutebrowser.' >&2
    exit 1
fi

error() {
    local msg="$*"
    echo "message-error '${msg//\'/\\\'}'" >> "$QUTE_FIFO"
}

msg() {
    local msg="$*"
    echo "message-info '${msg//\'/\\\'}'" >> "$QUTE_FIFO"
}

url="${QUTE_URL:-}"
if [[ ! $url =~ ^https://github\.com/NixOS/nixpkgs/pull/([0-9]+) ]]; then
    error 'This command only works on GitHub pull requests in NixOS/nixpkgs.'
    exit 0
fi

pr="${BASH_REMATCH[1]}"
if ! output=$(gh pr review "$pr" --repo NixOS/nixpkgs --approve --body '@NixOS/nixpkgs-merge-bot merge' 2>&1); then
    error "${output:-gh pr review failed.}"
    exit 0
fi

msg "Approved NixOS/nixpkgs#$pr and requested merge-bot merge."
