#!/usr/bin/env bash

export EDITOR="emacsclient"
export AMP_DEBUG=1
export AMP_LOG_LEVEL=debug

exec "$(dirname "$0")/agent-sandbox" \
	--share ~/.amp \
	--share ~/.bun \
	--share ~/.cache \
	--share ~/.config \
	--share ~/.docker \
	--share ~/.local \
	--share ~/.mcp-auth \
	--share ~/.npm \
	--share ~/.sourcegraph \
	--share ~/go/pkg \
	--share ~/src/github.com/keegancsmith/dotfiles/amp \
	-- amp --dangerously-allow-all "$@"
