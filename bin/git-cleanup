#!/usr/bin/env bash

set -euo pipefail

usage() {
	cat <<'EOF'
Usage: bin/git-cleanup [-f]

Lists local branches with a missing upstream ([gone]) by default.

Options:
  -f    delete listed branches with git branch -D
  -h    show this help
EOF
}

force=false
while getopts ":fh" opt; do
	case "${opt}" in
	f)
		force=true
		;;
	h)
		usage
		exit 0
		;;
	\?)
		echo "unknown option: -${OPTARG}" >&2
		usage >&2
		exit 1
		;;
	esac
done

shift $((OPTIND - 1))

if [[ $# -ne 0 ]]; then
	usage >&2
	exit 1
fi

git rev-parse --is-inside-work-tree >/dev/null

current_branch="$(git branch --show-current)"

mapfile -t gone_branches < <(
	git for-each-ref refs/heads --format='%(refname:short)|%(upstream:short)|%(upstream:track)' |
		awk -F'|' '$2 != "" && $3 ~ /gone/ {print $1}'
)

filtered_branches=()
for branch in "${gone_branches[@]}"; do
	if [[ -n ${current_branch} && ${branch} == "${current_branch}" ]]; then
		continue
	fi
	filtered_branches+=("${branch}")
done

if [[ ${#filtered_branches[@]} -eq 0 ]]; then
	echo "no local branches with gone upstreams"
	exit 0
fi

refs=()
for branch in "${filtered_branches[@]}"; do
	refs+=("refs/heads/${branch}")
done

if [[ ${force} == false ]]; then
	echo "local branches with gone upstreams (run with -f to delete):"
	git for-each-ref --sort=committerdate "${refs[@]}" \
		--format='%(HEAD) %(align:20,left)%(color:yellow)%(refname:short)%(color:reset)%(end) %(objectname:short)%(color:reset) %(color:blue)%(upstream:track)%(color:reset) %(contents:subject) (%(color:green)%(committerdate:relative)%(color:reset))'
	exit 0
fi

echo "deleting ${#filtered_branches[@]} local branches with gone upstreams"
for branch in "${filtered_branches[@]}"; do
	git branch -D "${branch}"
done
